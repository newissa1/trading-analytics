


import sys
import os 
sys.path.insert(0, os.path.dirname(os.getcwd()))


import pandas as pd
import numpy as np
import plotly.graph_objects as go
import plotly.express as px
import plotly.subplots as make_subplots 
import warnings
warnings.filterwarnings('ignore')



sys.path.insert(0, os.getcwd())
from data.loader import load_trades, summary_metrics

df = load_trades(os.path.expanduser('~/trading-analytics/data/Combined closed_positions.xlsx'))
m  = summary_metrics(df)
print(f"✓ Loaded {len(df):,} trades")
print(f"  Date range  : {m['date_range']}")
print(f"  Instruments : {df['Instrument'].nunique()}")
print(f"  Asset types : {df['Asset_Class'].unique().tolist()}")





print("=" * 45)
print("  BASELINE PERFORMANCE METRICS")
print("=" * 45)

metrics_display = {
    "Total Trades"        : f"{m['total_trades']:,}",
    "Net P&L"             : f"${m['net_pnl']:,.2f}",
    "Win Rate"            : f"{m['win_rate']}%",
    "Avg Win"             : f"${m['avg_win']}",
    "Avg Loss"            : f"${m['avg_loss']}",
    "Risk-Reward Ratio"   : f"{m['risk_reward']}",
    "Profit Factor"       : f"{m['profit_factor']}",
    "Expectancy/Trade"    : f"${m['expectancy']}",
    "Max Drawdown"        : f"${m['max_drawdown']:,.2f}",
    "Sharpe Ratio"        : f"{m['sharpe_ratio']}",
    "Total Commission"    : f"${m['total_commission']}",
    "Avg Hold Time"       : f"{m['avg_duration_mins']} mins",
    "Date Range"          : m['date_range'],
}

for k, v in metrics_display.items():
    print(f"  {k:<22} : {v}")


fig = go.Figure()

fig.add_trace(go.Scatter(
    x=df['Close Time'],
    y=df['Cumulative_PnL'],
    mode='lines',
    name='Equity Curve',
    line=dict(color='#2196F3', width=2),
    fill='tozeroy',
    fillcolor='rgba(33,150,243,0.1)'
))

fig.add_trace(go.Scatter(
    x=df['Close Time'],
    y=df['Drawdown'],
    mode='lines',
    name='Drawdown',
    line=dict(color='#F44336', width=1.5),
    fill='tozeroy',
    fillcolor='rgba(244,67,54,0.1)'
))

fig.add_hline(y=0, line_dash='dash', line_color='gray', opacity=0.5)

fig.update_layout(
    title='Equity Curve & Drawdown — Oct 2025 to Jun 2026',
    xaxis_title='Date',
    yaxis_title='Cumulative P&L ($)',
    template='plotly_white',
    height=500,
    legend=dict(orientation='h', y=1.1),
    hovermode='x unified'
)

fig.show()





instrument_stats = df.groupby('Instrument').agg(
    Trades       = ('Total Profit', 'count'),
    Net_PnL      = ('Total Profit', 'sum'),
    Win_Rate     = ('Win', 'mean'),
    Avg_Win      = ('Total Profit', lambda x: x[x > 0].mean()),
    Avg_Loss     = ('Total Profit', lambda x: x[x < 0].mean()),
).reset_index()

instrument_stats['Win_Rate']    = (instrument_stats['Win_Rate'] * 100).round(1)
instrument_stats['Net_PnL']     = instrument_stats['Net_PnL'].round(2)
instrument_stats['Avg_Win']     = instrument_stats['Avg_Win'].round(2)
instrument_stats['Avg_Loss']    = instrument_stats['Avg_Loss'].round(2)
instrument_stats['Edge']        = instrument_stats['Net_PnL'] > 0

instrument_stats = instrument_stats.sort_values('Net_PnL', ascending=False)

print(instrument_stats[['Instrument','Trades','Net_PnL','Win_Rate','Avg_Win','Avg_Loss']].to_string(index=False))


fig = px.bar(
    instrument_stats,
    x='Net_PnL',
    y='Instrument',
    orientation='h',
    color='Net_PnL',
    color_continuous_scale=['#F44336', '#FF9800', '#4CAF50'],
    color_continuous_midpoint=0,
    title='Net P&L by Instrument — Where Does Edge Exist?',
    labels={'Net_PnL': 'Net P&L ($)', 'Instrument': ''},
    height=700
)

fig.add_vline(x=0, line_dash='dash', line_color='black', opacity=0.4)

fig.update_layout(
    template='plotly_white',
    coloraxis_showscale=False,
    xaxis_title='Net P&L ($)',
    yaxis=dict(autorange='reversed')
)

fig.show()


profitable = instrument_stats[instrument_stats['Net_PnL'] > 0]
losing     = instrument_stats[instrument_stats['Net_PnL'] < 0]

print(f"Profitable instruments : {len(profitable)} / {len(instrument_stats)}")
print(f"Losing instruments     : {len(losing)} / {len(instrument_stats)}")
print(f"\nTop 3 instruments by Net P&L:")
print(profitable.head(3)[['Instrument','Trades','Net_PnL','Win_Rate']].to_string(index=False))
print(f"\nBottom 3 instruments by Net P&L:")
print(losing.tail(3)[['Instrument','Trades','Net_PnL','Win_Rate']].to_string(index=False))
print(f"\nCapital concentrated in losing instruments:")
print(f"  XAUUSD alone : {instrument_stats[instrument_stats['Instrument']=='XAUUSD']['Trades'].values[0]} trades ({instrument_stats[instrument_stats['Instrument']=='XAUUSD']['Trades'].values[0]/len(df)*100:.1f}% of all trades)")
print(f"  NQ100  alone : {instrument_stats[instrument_stats['Instrument']=='NQ100.']['Trades'].values[0]} trades ({instrument_stats[instrument_stats['Instrument']=='NQ100.']['Trades'].values[0]/len(df)*100:.1f}% of all trades)")





session_stats = df.groupby('Session').agg(
    Trades   = ('Total Profit', 'count'),
    Net_PnL  = ('Total Profit', 'sum'),
    Win_Rate = ('Win', 'mean'),
    Avg_PnL  = ('Total Profit', 'mean'),
).reset_index()

session_stats['Win_Rate'] = (session_stats['Win_Rate'] * 100).round(1)
session_stats['Net_PnL']  = session_stats['Net_PnL'].round(2)
session_stats['Avg_PnL']  = session_stats['Avg_PnL'].round(2)
session_stats = session_stats.sort_values('Net_PnL', ascending=False)

print(session_stats.to_string(index=False))

fig = px.bar(
    session_stats,
    x='Session',
    y='Net_PnL',
    color='Net_PnL',
    color_continuous_scale=['#F44336', '#4CAF50'],
    color_continuous_midpoint=0,
    title='Net P&L by Trading Session',
    text='Net_PnL',
    height=400
)

fig.update_traces(texttemplate='$%{text:.0f}', textposition='outside')
fig.update_layout(template='plotly_white', coloraxis_showscale=False)
fig.show()


dow_order = ['Monday','Tuesday','Wednesday','Thursday','Friday']

dow_stats = df.groupby('DOW').agg(
    Trades   = ('Total Profit', 'count'),
    Net_PnL  = ('Total Profit', 'sum'),
    Win_Rate = ('Win', 'mean'),
).reset_index()

dow_stats['Win_Rate'] = (dow_stats['Win_Rate'] * 100).round(1)
dow_stats['Net_PnL']  = dow_stats['Net_PnL'].round(2)
dow_stats['DOW']      = pd.Categorical(dow_stats['DOW'], categories=dow_order, ordered=True)
dow_stats             = dow_stats.sort_values('DOW')

print(dow_stats.to_string(index=False))

fig = px.bar(
    dow_stats,
    x='DOW',
    y='Net_PnL',
    color='Net_PnL',
    color_continuous_scale=['#F44336', '#4CAF50'],
    color_continuous_midpoint=0,
    title='Net P&L by Day of Week',
    text='Net_PnL',
    height=400
)

fig.update_traces(texttemplate='$%{text:.0f}', textposition='outside')
fig.update_layout(template='plotly_white', coloraxis_showscale=False)
fig.show()



